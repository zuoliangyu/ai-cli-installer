{
  "version": 1,
  "updated_at": "2026-05-10",
  "comment": "Built-in fix recipes from OCC docs (https://docs.openclaudecode.cn) and Claude Code docs (https://code.claude.com/docs/en/settings). Each fix is a list of patches that get merged into ~/.claude/settings.json or ~/.claude.json.",
  "fixes": [
    {
      "id": "cc-006-disable-betas",
      "code": "CC-006",
      "title": "禁用实验性 Beta 参数",
      "description": "AWS 分组上游不接受 anthropic-beta 请求头，会返回 400 invalid beta flag。开启后 Claude Code 不再附加该头。",
      "doc_url": "https://docs.openclaudecode.cn/#/errors/cc-400-experimental-betas",
      "patches": [
        {
          "target": "claude_settings",
          "path": "env.CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS",
          "value": "1"
        }
      ]
    },
    {
      "id": "cc-017-skip-webfetch-preflight",
      "code": "CC-017",
      "title": "跳过 WebFetch 预检（国内网络强烈推荐）",
      "description": "WebFetch 抓页面前会先请求 claude.ai 做域名预检；国内网络/防火墙拦掉后整个 WebFetch 失效。开启后跳过预检，直接抓目标页面。",
      "doc_url": "https://docs.openclaudecode.cn/#/errors/cc-webfetch-preflight-fail",
      "patches": [
        {
          "target": "claude_settings",
          "path": "skipWebFetchPreflight",
          "value": true
        }
      ]
    },
    {
      "id": "cc-005-onboarding-done",
      "code": "CC-005",
      "title": "标记 Onboarding 已完成（绕过首次启动连通性校验）",
      "description": "Claude Code 首次启动会向 api.anthropic.com 做连通性校验，不受中转地址影响，国内/中转用户被卡在登录前。该字段写入 ~/.claude.json 跳过此校验。",
      "doc_url": "https://docs.openclaudecode.cn/#/errors/cc-onboarding-connection-block",
      "patches": [
        {
          "target": "claude_json",
          "path": "hasCompletedOnboarding",
          "value": true
        }
      ]
    },
    {
      "id": "enable-powershell-tool",
      "code": "CC-WIN",
      "title": "启用 PowerShell 工具",
      "description": "允许 Claude Code 使用 PowerShell 工具。Windows + Git Bash 环境可用来主动开启原生 PowerShell；Linux/macOS/WSL 需确保 pwsh 在 PATH 中。",
      "doc_url": "https://code.claude.com/docs/en/env-vars",
      "patches": [
        {
          "target": "claude_settings",
          "path": "env.CLAUDE_CODE_USE_POWERSHELL_TOOL",
          "value": "1"
        }
      ]
    },
    {
      "id": "default-shell-powershell",
      "code": "CC-WIN",
      "title": "将 ! 命令默认改为 PowerShell",
      "description": "把输入框里的 ! 命令默认交给 PowerShell 执行。适合主要使用 PowerShell 的 Windows 用户；如未启用 PowerShell 工具，请先单独应用对应配置。",
      "doc_url": "https://code.claude.com/docs/en/settings",
      "patches": [
        {
          "target": "claude_settings",
          "path": "defaultShell",
          "value": "powershell"
        }
      ]
    },
    {
      "id": "maintain-project-working-dir",
      "code": "CC-SHELL",
      "title": "命令执行后回到项目目录",
      "description": "让 Claude Code 的 Bash 或 PowerShell 命令执行后回到会话最初的工作目录，减少 cd 到子目录后影响后续命令的情况。",
      "doc_url": "https://code.claude.com/docs/en/env-vars",
      "patches": [
        {
          "target": "claude_settings",
          "path": "env.CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR",
          "value": "1"
        }
      ]
    },
    {
      "id": "disable-bypass-permissions-mode",
      "code": "CC-SAFE",
      "title": "禁用跳过权限模式",
      "description": "阻止 Claude Code 启用 bypassPermissions 模式，同时禁用 --dangerously-skip-permissions，降低误进入高风险权限模式的可能。",
      "doc_url": "https://code.claude.com/docs/en/settings",
      "patches": [
        {
          "target": "claude_settings",
          "path": "permissions.disableBypassPermissionsMode",
          "value": "disable"
        }
      ]
    },
    {
      "id": "scrub-subprocess-env",
      "code": "CC-SAFE",
      "title": "子进程环境变量脱敏",
      "description": "从 Bash、PowerShell、hooks、MCP stdio 子进程环境中剥离 Anthropic 和云厂商凭据，降低命令执行时泄露密钥的风险。Linux 上会启用额外进程隔离。",
      "doc_url": "https://code.claude.com/docs/en/env-vars",
      "patches": [
        {
          "target": "claude_settings",
          "path": "env.CLAUDE_CODE_SUBPROCESS_ENV_SCRUB",
          "value": "1"
        }
      ]
    },
    {
